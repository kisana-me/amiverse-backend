<div style="border-bottom: 1px solid #ddd; padding: 0.4rem 0; display: flex; gap: 1rem; align-items: baseline; flex-wrap: wrap;">
  <span style="color: #888; font-size: 0.85rem;"><%= coin_transaction.created_at.strftime("%Y-%m-%d %H:%M") %></span>
  <span><%= t("activerecord.enums.coin_transaction.kind.#{coin_transaction.kind}") %></span>
  <span style="font-weight: bold; color: <%= coin_transaction.amount.negative? ? "#d32f2f" : "#2e7d32" %>;">
    <%= coin_transaction.amount.positive? ? "+" : "" %><%= number_with_delimiter coin_transaction.amount %>
  </span>
  <span style="color: #888;">残高 <%= number_with_delimiter coin_transaction.balance_after %></span>
  <% if coin_transaction.memo.present? %>
    <span style="color: #555;">📝 <%= coin_transaction.memo %></span>
  <% end %>
  <%= link_to "詳細", coin_transaction_path(coin_transaction.aid) %>
</div>
