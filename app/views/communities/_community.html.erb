<div id="<%= community.aid %>">
  <div style="display: flex; gap: 0.5rem;">
    <div style="width: 3rem; height: 3rem;">
      <%= image_tag community.icon_url, style: "width: 100%; height: 100%; object-fit: cover;" %>
    </div>
    <div style="height: 3rem;">
      <div style="line-height: 1.5rem; font-weight: bold;"><%= community.name %></div>
      <div style="line-height: 1.5rem;"><%= community.aid %></div>
    </div>
  </div>
</div>
