<% content_for :title, "コミュニティ一覧" %>

<h1>コミュニティ一覧</h1>

<div style="margin-bottom: 0.5rem;"><%= link_to "新規作成", new_community_path %></div>

<div id="communities" style="display: flex; flex-direction: column; gap: 0.25rem;">
  <% @communities.each do |community| %>
    <div style="border: 1px solid #373737; border-radius: 0.25rem; padding: 0.25rem;">
      <%= render community %>
      <div>
        <div>AID: <%= community.aid %></div>
        <div>状態:
          <span style="<% if community.status == "locked" %>color: #ff5722;<% end %><% if community.status == "deleted" %>color: red;<% end %>">
            <%= community.status %>
          </span>
          / 公開: <%= community.visibility %>
        </div>
        <div>操作: <%= link_to "コミュニティ詳細", community_path(community.aid) %></div>
      </div>
    </div>
  <% end %>
</div>

<%= render "shared/paging", page: @page, pages: @total_pages, page_to: communities_path %>
