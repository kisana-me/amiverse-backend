<%= form_with(model: community, url: url, class: "ctmf", multipart: true, data: { turbo: false }) do |form| %>
  <%= render "shared/error_messages", instead: community %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :description %>
    <%= form.text_area :description %>
  </div>

  <div>
    <%= form.label :founder_aid, "創設者 (aid)" %>
    <%= form.text_field :founder_aid, value: community.founder&.aid %>
  </div>

  <div>
    <%= form.label :icon_file, "アイコン" %>
    <%= form.file_field :icon_file, accept: "image/*" %>
  </div>

  <div>
    <%= form.label :banner_file, "バナー" %>
    <%= form.file_field :banner_file, accept: "image/*" %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.select :status, Community.statuses.keys.map { |k| [t("activerecord.enums.community.status.#{k}"), k] }, {} %>
  </div>

  <div>
    <%= form.label :visibility, style: "display: block" %>
    <%= form.select :visibility, Community.visibilities.keys.map { |k| [t("activerecord.enums.community.visibility.#{k}"), k] }, {} %>
  </div>

  <div>
    <%= form.submit "送信" %>
  </div>
<% end %>
