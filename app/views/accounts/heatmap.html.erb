<% if @account %>
  <h1>Post Heatmap</h1>
  <p>
    <strong><%= @account.name %></strong> (@<%= @account.name_id %>) — 直近1年 / 最大 <%= @max %> 投稿/日
    &nbsp;|&nbsp; <%= link_to "アカウント詳細", account_path(@account.aid) %>
  </p>

  <div style="display: inline-grid; grid-auto-flow: column; grid-template-rows: repeat(7, 12px); gap: 3px;">
    <% @days.each do |day| %>
      <%
        bg =
          if day[:count].positive?
            intensity = @max.zero? ? 0 : day[:count].to_f / @max
            alpha = (0.25 + intensity * 0.75).round(2)
            "rgba(70, 190, 27, #{alpha})"
          elsif day[:visited]
            "#dadada"
          else
            "#f0f0f0"
          end
        label = "#{day[:date]}: #{day[:count]}投稿#{day[:visited] ? ' / ログイン' : ''}"
      %>
      <div title="<%= label %>" style="width: 12px; height: 12px; border-radius: 2px; background: <%= bg %>;"></div>
    <% end %>
  </div>

  <p style="margin-top: 12px; font-size: 12px; color: #666;">
    緑 = 投稿あり（濃いほど多い） / グレー = ログインのみ / 薄 = なし
  </p>
<% else %>
  <h1>Post Heatmap</h1>
  <p>アカウントが見つかりませんでした。</p>
<% end %>
