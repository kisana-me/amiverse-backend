<%= form_with(model: account, url: url, class: "ctmf", data: { turbo: false }) do |form| %>
  <%= render "shared/error_messages", instead: account %>

  <div>
    <%= form.label :name_id %>
    <%= form.text_field :name_id %>
  </div>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :email, "email" %>
    <%= form.email_field :email %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.select :status, Account.statuses.keys.map { |k| [t("activerecord.enums.account.status.#{k}"), k] }, {} %>
  </div>

  <div>
    <%= form.submit "送信" %>
  </div>
<% end %>
