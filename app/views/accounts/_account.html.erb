<div id="<%= account.aid %>">
  <div style="display: flex; gap: 0.5rem;">
    <div style="width: 3rem; height: 3rem;">
      <%= image_tag account.icon_url, style: "width: 100%; height: 100%" %>
    </div>
    <div style="height: 3rem;">
      <div style="line-height: 1.5rem; font-weight: bold;"><%= account.name %></div>
      <div style="line-height: 1.5rem;">@<%= account.name_id %></div>
    </div>
  </div>
</div>
