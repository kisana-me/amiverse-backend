<%= form_with model: post, url: url, style: "ctmf", data: { turbo: false } do |form| %>
  <%= render "shared/error_messages", instead: post %>

  <div>
    <%= form.label :visibility %>
    <%= form.select :visibility, Post.visibilities.keys.map { |k| [t("activerecord.enums.post.visibility.#{k}"), k] }, {} %>
  </div>

  <div>
    <%= form.label :status %>
    <%= form.select :status, Post.statuses.keys.map { |k| [t("activerecord.enums.post.status.#{k}"), k] }, {} %>
  </div>

  <div>
    <%= form.label :mod_rating, "レーティング(運営上書き)" %>
    <%= form.select :mod_rating,
      Post.mod_ratings.keys.map { |k| [t("activerecord.enums.post.rating.#{k}"), k] },
      { include_blank: "(上書きなし)" } %>
    <small>
      実効: <%= t("activerecord.enums.post.rating.#{post.rating_label}") %>
      / 申告: <%= t("activerecord.enums.post.rating.#{post.user_rating}") %>
      / 自動: <%= post.auto_rating ? t("activerecord.enums.post.rating.#{post.auto_rating}") : "未判定" %>
    </small>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
