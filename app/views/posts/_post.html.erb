<div class="post">
  <%= render post.account %>
  <hr />

  <p><%= post.content %></p>
  <% post.images.each do |image| %>
    <%= image_tag image.image_url, style: "width: 200px; height: 150px; object-fit: contain;" %>
  <% end %>
  <% post.videos.each do |video| %>
    <%= video_tag video.video_url, style: "width: 200px; height: 150px; object-fit: contain;", controls: true %>
  <% end %>
  <% post.drawings.each do |drawing| %>
    <%= image_tag drawing.image_url, style: "width: 320px; height: 120px; border: 1px solid #cfc;" %>
  <% end %>
  <hr />

  <% if post.reply %>
    <%= link_to "返信先があります", post_path(post.reply.aid) if post.reply %>
  <% else %>
    返信先はありません
  <% end %>
  <% if post.quote %>
    <%= link_to "引用元があります", post_path(post.quote.aid) %>
  <% else %>
    引用元はありません
  <% end %>
  <small><%= post.created_at.strftime("%Y-%m-%d %H:%M:%S") %></small>
  <hr />

  <div class="post-reactions" style="margin-bottom: 10px;">
    <% my_reacted_emoji_ids = @current_account ? post.reactions.where(account: @current_account).pluck(:emoji_id) : [] %>
    <% post.reactions.group(:emoji).count.each do |emoji, count| %>
      <% is_reacted_by_me = my_reacted_emoji_ids.include?(emoji.id) %>
      <div style="display: inline-block; border: 1px solid <%= is_reacted_by_me ? '#007bff' : '#ccc' %>; background-color: <%= is_reacted_by_me ? '#e7f1ff' : 'transparent' %>; border-radius: 10px; padding: 2px 5px; margin-right: 5px;">
          <% if emoji.image %>
             <%= image_tag emoji.image_url, style: "width: 20px; height: 20px; vertical-align: middle;" %>
          <% else %>
             <%= emoji.name %>
          <% end %>
          <span style="margin-left: 3px;"><%= count %></span>
      </div>
    <% end %>
  </div>

  <div>
    <%= render "emojis/picker", mode: 'reaction', target_id: post.aid %>

    <% if post.diffuses.exists?(account: @current_account) %>
      <%= button_to "Undiffuse", undiffuse_path(post_aid: post.aid), method: :delete, style: "display: inline-block; margin-left: 10px; color: green;" %>
    <% else %>
      <%= button_to "Diffuse", diffuse_path(post_aid: post.aid), method: :post, style: "display: inline-block; margin-left: 10px;" %>
    <% end %>

    reactions, replies, quotes, views, menu.
  </div>
</div>
