<% provide(:title, "絵文字グループ: #{@group_name}") %>

<h1>絵文字グループ: <%= @group_name %></h1>

<p>
  <%= link_to "絵文字グループ一覧に戻る", emojis_path %>
</p>

<% if @emojis.blank? %>
  <p>このグループの絵文字はありません</p>
<% else %>
  <p>件数: <%= @emojis.size %></p>

  <div class="emojis" style="display: flex; flex-wrap: wrap; gap: 1rem;">
    <% @emojis.each do |emoji| %>
      <%= link_to emoji_path(emoji.aid), style: "min-width: 48px; height: 48px; border: 1px solid " + status_color(emoji.status) + "; display: flex; align-items: center; justify-content: center; text-decoration: none; color: inherit;" do %>
        <% if emoji.image.present? %>
          <%= image_tag emoji.image_url, alt: (emoji.name.presence || emoji.name_id), style: "height: 100%;" %>
        <% else %>
          <%= emoji.name.presence || "_?" %>
        <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>
