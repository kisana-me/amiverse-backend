<%= form_with(model: session, url: url, class: "ctmf", data: { turbo: false }) do |form| %>
  <%= render "shared/error_messages", instead: session %>

  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.select :status, Session.statuses.keys.map { |k| [t("activerecord.enums.session.status.#{k}"), k] }, {} %>
  </div>

  <div>
    <%= form.submit "送信" %>
  </div>
<% end %>
