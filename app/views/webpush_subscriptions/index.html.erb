<% provide(:title, "WebPushSubscription一覧") %>

<h1>WebPushSubscription一覧</h1>

<div style="margin-bottom: 0.25rem;">
  <%= render @account %>
</div>

<div class="webpush-subscriptions" style="display: flex; flex-direction: column; gap: 0.25rem;">
  <% @webpush_subscriptions.each do |subscription| %>
    <div style="border: 1px solid #373737; border-radius: 0.25rem; padding: 0.25rem;">
      <div>ID: <%= subscription.id %></div>
      <div>名前: <%= subscription.name %></div>
      <div>状態:
        <span style="<% if subscription.status == "locked" %>color: #ff5722;<% end %><% if subscription.status == "deleted" %>color: red;<% end %>">
          <%= subscription.status %>
        </span>
      </div>
      <div>Endpoint: <%= subscription.endpoint.to_s.truncate(80) %></div>
      <div>UserAgent: <%= subscription.meta["user_agent"].to_s.truncate(80) %></div>
      <div>作成: <%= subscription.created_at.strftime("%Y/%m/%d %H:%M:%S") %></div>
      <div>更新: <%= subscription.updated_at.strftime("%Y/%m/%d %H:%M:%S") %></div>
      <div>操作: <%= link_to "WebPushSubscription詳細", account_webpush_subscription_path(@account.aid, subscription.id) %></div>
    </div>
  <% end %>
</div>

<%= render "shared/paging", page: @page, pages: @total_pages, page_to: account_webpush_subscriptions_path(@account.aid) %>
