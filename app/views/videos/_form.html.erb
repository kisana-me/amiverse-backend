<%= form_with model: @video, url: url, class: "ctmf", data: { turbo: false } do |f| %>
  <%= render "shared/error_messages", instead: @video %>

  <div>
    <%= f.label :name %>
    <%= f.text_field :name %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :visibility %>
    <%= f.select :visibility, Video.visibilities.keys.map { |k| [t("activerecord.enums.video.visibility.#{k}"), k] }, {} %>
  </div>

  <div>
    <%= f.label :status %>
    <%= f.select :status, Video.statuses.keys.map { |k| [t("activerecord.enums.video.status.#{k}"), k] }, {} %>
  </div>

  <div>
    <%= f.label :mod_rating, "レーティング(運営上書き)" %>
    <%= f.select :mod_rating,
      Video.mod_ratings.keys.map { |k| [t("activerecord.enums.video.rating.#{k}"), k] },
      { include_blank: "(上書きなし)" } %>
    <small>
      実効: <%= t("activerecord.enums.video.rating.#{@video.rating_label}") %>
      / 申告: <%= t("activerecord.enums.video.rating.#{@video.user_rating}") %>
      / 自動: <%= @video.auto_rating ? t("activerecord.enums.video.rating.#{@video.auto_rating}") : "未判定" %>
    </small>
  </div>

  <%= f.submit %>
<% end %>
