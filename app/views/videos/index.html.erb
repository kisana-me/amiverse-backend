<% provide(:title, "動画一覧") %>

<h1>動画一覧</h1>

<div id="videos" style="display: flex; flex-direction: row; flex-wrap: wrap; justify-content: center; gap: 2px;">
  <% @videos.each do |video| %>
    <div style="border: 1px solid #ccc; padding: 2px;">
      <div style="width: 200px; height: 200px;">
        <%= video_tag(video.video_url, style: "width: 100%; height: 100%; object-fit: contain;", controls: true) %>
      </div>
      <%= link_to "動画詳細", video_path(video.aid) %>
    </div>
  <% end %>
</div>

<%= render "shared/paging", pages: @total_pages, page: @page, page_to: "/videos" %>
